# Anthropic API key for the AI Component Generator.
# If omitted, the app automatically falls back to a deterministic
# mock generator so the feature still works in local/demo environments.
ANTHROPIC_API_KEY=

# Optional: OpenAI fallback provider instead of Anthropic
OPENAI_API_KEY=

# Which provider to use: "anthropic" | "openai" | "mock"
AI_PROVIDER=anthropic
